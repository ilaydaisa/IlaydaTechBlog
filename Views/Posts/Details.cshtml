@model IlaydaTechBlog.Models.Post

@{
    ViewData["Title"] = "Blog Detay";
}

<div class="container">
    <div class="page-header">
        <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Bloglara Dön</a>
    </div>

    <div class="post-detail-card">
        <div class="blog-meta mb-2">
            @Model.Author • @Model.CreatedAt.ToString("dd.MM.yyyy")
        </div>

        <h1 class="fw-bold mb-4">@Model.Title</h1>

        <div class="post-content">
            @Model.Content
        </div>
    </div>
</div>