@model IlaydaTechBlog.Models.AdminLoginViewModel

@{
    ViewData["Title"] = "Admin Giriş";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="form-card">
                <h1 class="text-center mb-4">Admin Giriş</h1>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.ErrorMessage
                    </div>
                }

                <form asp-controller="Admin" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">Kullanıcı Adı</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Şifre</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn custom-btn-primary w-100">Giriş Yap</button>
                </form>

                <div class="mt-3 text-center text-muted">
                    Demo giriş: <strong>admin</strong> / <strong>1234</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}